---
const base = '/KangPaket-web';
const screenshots = [
  {
    src: `${base}/screenshots/Request-Builder_v1.0.1.png`,
    alt: 'KangPaket Request Builder',
    caption: 'Request Builder',
    desc: 'Build HTTP requests with headers, auth, and various body formats.',
  },
  {
    src: `${base}/screenshots/Collection-Runner_v1.0.1.png`,
    alt: 'KangPaket Collection Runner',
    caption: 'Collection Runner',
    desc: 'Run entire collections at once with assertions and detailed result reports.',
  },
  {
    src: `${base}/screenshots/Postman-Import_v1.0.1.png`,
    alt: 'KangPaket Postman Import',
    caption: 'Postman Import',
    desc: 'Import Postman v2.0/v2.1 collections directly — no re-setup required.',
  },
];
---
<section id="screenshots" class="py-20 md:py-24 bg-gray-900/40">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-semibold text-gray-50 mb-4">Screenshots</h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        A clean, intuitive interface designed for team productivity.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {screenshots.map((s) => (
        <div class="group flex flex-col">
          <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900 shadow-lg shadow-black/30 transition-transform duration-200 group-hover:-translate-y-1">
            <img
              src={s.src}
              alt={s.alt}
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="mt-3 px-1">
            <p class="text-sm font-medium text-gray-300">{s.caption}</p>
            <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
