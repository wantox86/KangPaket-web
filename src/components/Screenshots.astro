---
const base = '/KangPaket-web';
const screenshots = [
  {
    src: `${base}/screenshots/main-window.svg`,
    alt: 'Main Window KangPaket',
    caption: 'Request Builder',
    desc: 'Bangun HTTP request dengan headers, auth, dan body berbagai format.',
  },
  {
    src: `${base}/screenshots/runner.svg`,
    alt: 'Collection Runner',
    caption: 'Collection Runner',
    desc: 'Jalankan seluruh koleksi sekaligus dengan assertions dan laporan hasil.',
  },
  {
    src: `${base}/screenshots/postman-import.svg`,
    alt: 'Import dari Postman',
    caption: 'Postman Import',
    desc: 'Import koleksi Postman v2.0/v2.1 langsung — tidak perlu setup ulang.',
  },
];
---
<section id="screenshots" class="py-20 md:py-24 bg-gray-900/40">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-semibold text-gray-50 mb-4">Tampilan Aplikasi</h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Antarmuka bersih dan intuitif, dirancang untuk produktivitas tim.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {screenshots.map((s) => (
        <div class="group flex flex-col">
          <div class="overflow-hidden rounded-xl border border-gray-800 bg-gray-900 shadow-lg shadow-black/30 transition-transform duration-200 group-hover:-translate-y-1">
            <!-- Window chrome -->
            <div class="flex items-center gap-1.5 px-3 py-2.5 border-b border-gray-800">
              <span class="h-2.5 w-2.5 rounded-full bg-red-500/60"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/60"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-500/60"></span>
              <span class="ml-2 text-xs text-gray-600 font-mono">{s.caption}</span>
            </div>
            <img
              src={s.src}
              alt={s.alt}
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="mt-3 px-1">
            <p class="text-sm font-medium text-gray-300">{s.caption}</p>
            <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
