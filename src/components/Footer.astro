---
const base = '/KangPaket-web';
---
<footer class="border-t border-gray-800 bg-gray-950 py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo + tagline -->
      <div class="flex flex-col items-center md:items-start gap-1">
        <a href={`${base}/`} class="flex items-center gap-2 font-semibold text-gray-50">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          </svg>
          KangPaket
        </a>
        <p class="text-sm text-gray-500">API client offline untuk tim internal</p>
      </div>

      <!-- Links -->
      <nav class="flex items-center gap-6 text-sm text-gray-500">
        <a href="https://github.com/wantox86/KangPaket" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">GitHub</a>
        <a href={`${base}/changelog`} class="hover:text-gray-300 transition-colors">Changelog</a>
        <a href="https://github.com/wantox86/KangPaket/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">License (MIT)</a>
      </nav>
    </div>

    <div class="mt-8 border-t border-gray-800 pt-6 text-center text-sm text-gray-600">
      © 2025 KangPaket — Open Source under MIT License
    </div>
  </div>
</footer>
