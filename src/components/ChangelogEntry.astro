---
interface Props {
  version: string;
  date: string;
}
const { version, date } = Astro.props;
---
<article class="relative pl-8 pb-10 last:pb-0">
  <!-- Timeline line -->
  <div class="absolute left-0 top-2 bottom-0 w-px bg-gray-800 last:hidden"></div>
  <!-- Timeline dot -->
  <div class="absolute left-0 top-2 -translate-x-1/2 h-3 w-3 rounded-full border-2 border-brand bg-gray-950"></div>

  <div class="flex flex-wrap items-center gap-3 mb-3">
    <span class="rounded-md bg-brand/10 border border-brand/20 px-2.5 py-0.5 text-sm font-mono font-medium text-brand">
      {version}
    </span>
    <span class="text-sm text-gray-500">{date}</span>
  </div>

  <div class="text-sm text-gray-400 leading-relaxed space-y-1 [&>ul]:list-none [&>ul]:p-0 [&>ul>li]:flex [&>ul>li]:gap-2 [&>ul>li]:items-start [&>ul>li]:before:content-['—'] [&>ul>li]:before:text-gray-600 [&>ul>li]:before:shrink-0">
    <slot />
  </div>
</article>
