---
const base = '/KangPaket-web';
---
<section class="relative overflow-hidden py-20 md:py-28">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-30"></div>
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-gray-950"></div>
  <!-- Brand glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-brand/10 rounded-full blur-3xl"></div>

  <div class="relative mx-auto max-w-4xl px-4 sm:px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 rounded-full border border-brand/30 bg-brand/10 px-4 py-1.5 text-sm text-brand mb-8">
      <span class="h-1.5 w-1.5 rounded-full bg-brand animate-pulse"></span>
      Open Source · v1.0.1
    </div>

    <!-- Tagline -->
    <h1 class="text-5xl md:text-6xl font-semibold text-gray-50 leading-tight tracking-tight mb-6">
      Lightweight API Client<br />
      <span class="text-brand">for Internal Teams</span>
    </h1>

    <!-- Sub-tagline -->
    <p class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto mb-10">
      A Postman alternative that runs fully offline, no subscription needed,
      and customizable to fit your team's workflow.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href={`${base}/#download`}
        class="flex items-center gap-2 rounded-lg bg-brand hover:bg-brand-dark text-gray-950 font-medium px-6 py-3 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for Windows
      </a>
      <a
        href="https://github.com/wantox86/KangPaket"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-gray-100 px-6 py-3 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        Star on GitHub
      </a>
    </div>

    <!-- Main screenshot -->
    <div class="relative mx-auto max-w-3xl rounded-xl border border-gray-800 bg-gray-900 shadow-2xl shadow-black/50 overflow-hidden">
      <!-- Window chrome -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800 bg-gray-900">
        <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
        <span class="ml-4 text-xs text-gray-500 font-mono">KangPaket v1.0.1</span>
      </div>
      <img
        src={`${base}/screenshots/main-window.svg`}
        alt="KangPaket main window"
        class="w-full"
        loading="eager"
      />
    </div>
  </div>
</section>
