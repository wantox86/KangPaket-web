---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ChangelogEntry from '../components/ChangelogEntry.astro';
---
<BaseLayout
  title="Changelog"
  description="Release history and notes for KangPaket."
>
  <Navbar />
  <main class="mx-auto max-w-2xl px-4 sm:px-6 py-16 md:py-24">
    <div class="mb-12">
      <h1 class="text-4xl font-semibold text-gray-50 mb-3">Changelog</h1>
      <p class="text-gray-400">
        Release history for KangPaket. View all releases on
        <a
          href="https://github.com/wantox86/KangPaket/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand hover:text-brand-dark transition-colors"
        >GitHub Releases</a>.
      </p>
    </div>

    <div class="relative">
      <ChangelogEntry version="v1.0.1" date="March 1, 2025">
        <ul>
          <li>Fix: PyInstaller bundle missing customtkinter</li>
          <li>Fix: httpx hidden import on Windows build</li>
        </ul>
      </ChangelogEntry>

      <ChangelogEntry version="v1.0.0" date="February 15, 2025">
        <ul>
          <li>Initial release</li>
          <li>HTTP request builder — all methods, auth, body types</li>
          <li>Collection Runner with 7 assertions</li>
          <li>Import from Postman Collection v2.0 & v2.1</li>
          <li>Export/import profile JSON</li>
        </ul>
      </ChangelogEntry>
    </div>
  </main>
  <Footer />
</BaseLayout>
